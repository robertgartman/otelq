# Point the app you are debugging at the local dev Collector's OTLP gRPC endpoint.
# The app itself decides whether to emit telemetry (it sets OTEL_ENABLED, not otelq).
# otelq needs no environment — it reads the JSONL files in ./.telemetry directly.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional: per-worktree telemetry tagging (SPEC-otelq-worktree-scoping).
# When several git worktrees share one dev Collector, tag each worktree's signals
# so otelq can scope errors/slow/logs/metric to the worktree you are working in
# (rows without the tag are always still shown). This is OPT-IN: nothing changes
# until the telemetry actually carries otelq.worktree.id.
#
# Run `otelq set_resource_attributes` from a worktree to have otelq write the
# git-derived values into ./.env.local for you, then source that file before
# launching the instrumented app. You can also set the value by hand and add any
# bespoke attributes you like (comma-separated key=value pairs):
# OTEL_RESOURCE_ATTRIBUTES="otelq.worktree.id=/abs/path/to/worktree,otelq.worktree.branch=feature-x,team=payments"
